# ─── Echoes of Home — Environment Variables ───────────────────────────────────
# Copy this file to .env.local and fill in your API keys.
# .env.local is gitignored and should NEVER be committed.

# ── Vapi ──────────────────────────────────────────────────────────────────────
# Get these from https://dashboard.vapi.ai → Settings → API Keys
NEXT_PUBLIC_VAPI_PUBLIC_KEY=your_vapi_public_key_here
VAPI_PRIVATE_KEY=your_vapi_private_key_here

# ── Gemini ────────────────────────────────────────────────────────────────────
# Used for Gemini Vision (image analysis) and tool answer generation
# Get from https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ── Cartesia ──────────────────────────────────────────────────────────────────
# Used if you call Cartesia directly (optional — Vapi handles TTS internally)
# Get from https://play.cartesia.ai → API Keys
CARTESIA_API_KEY=your_cartesia_api_key_here

# ── Instagram ─────────────────────────────────────────────────────────────────
# Used for Instagram OAuth (connect your Instagram account to browse your posts)
# Create an app at https://developers.facebook.com → My Apps → Add Product → Instagram
# Redirect URI to configure: {NEXT_PUBLIC_APP_URL}/api/auth/instagram/callback
INSTAGRAM_APP_ID=your_instagram_app_id_here
INSTAGRAM_APP_SECRET=your_instagram_app_secret_here

# ── TikTok ────────────────────────────────────────────────────────────────────
# Used for TikTok OAuth (connect your TikTok account to browse your videos)
# Create an app at https://developers.tiktok.com → Manage Apps
# Redirect URI to configure: {NEXT_PUBLIC_APP_URL}/api/auth/tiktok/callback
TIKTOK_CLIENT_KEY=your_tiktok_client_key_here
TIKTOK_CLIENT_SECRET=your_tiktok_client_secret_here

# ── App URL ───────────────────────────────────────────────────────────────────
# Used for Vapi tool webhook URLs and OAuth redirect URIs
# Set to your production URL when deploying
NEXT_PUBLIC_APP_URL=http://localhost:3000
